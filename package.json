{
  "name": "wedding-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "turbo run typecheck",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "prettier": "^3.9.5",
    "sharp": "0.35.3",
    "turbo": "^2.10.5",
    "typescript": "^5.9.2"
  }
}
